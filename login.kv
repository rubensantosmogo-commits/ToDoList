Screen:

    MDCard:
        size_hint: None, None
        size: 300, 400
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
        orientation: "vertical"
        padding: 25
        spacing: 25

        MDLabel:
            id: welcome_label
            text: "Welcome"
            font_size: 25
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]
            padding_y: 15

        MDTextField:
            id: user
            hint_text: "Username"
            size_hint_x: None
            width: 200
            font_size: "18sp"
            icon_right: "account"
            pos_hint: {"center_x": 0.5}

        MDTextField:
            id: password
            password: True
            hint_text: "Password"
            size_hint_x: None
            width: 200
            font_size: "18sp"
            icon_right: "eye-off"
            pos_hint: {"center_x": 0.5}

        MDRoundFlatButton:
            text: "Login"
            font_size: 18
            pos_hint: {"center_x": 0.5}
            on_press: app.logger()
        
        MDRoundFlatButton:
            text: "Clear"
            font_size: 18
            pos_hint: {"center_x": 0.5}
            on_press: app.clear()

        MDRoundFlatButton:
            text: "Register"
            font_size: 18
            pos_hint: {"center_x": 0.5}
            on_press: app.register()